/* === LaBo TV Base Theme === */

:root {
  --primary-color: #ff6a00;
  --background-dark: #0f0f0f;
  --card-radius: 12px;
}

/* Background */
body {
  background-color: var(--background-dark) !important;
}

/* Remove clutter */
.sectionTitle,
.sectionTitleTextButton,
.emby-tabs-slider {
  display: none !important;
}

/* Poster cards */
.cardBox {
  border-radius: var(--card-radius) !important;
  overflow: hidden;
  transition: transform 0.15s ease;
}

.cardBox:hover {
  transform: scale(1.05);
}

/* Reduce text noise */
.cardText {
  font-size: 0.8em !important;
  opacity: 0.7;
}

/* Hide unnecessary UI */
.detailImageContainer,
.backgroundContainer {
  display: none !important;
}

/* Limit rows visually */
.itemsContainer {
  max-height: 260px;
  overflow: hidden;
}

/* Bigger posters */
.cardBox {
  width: 180px !important;
}

/* Login branding */
#loginPage {
  background: linear-gradient(180deg, #000, #111);
}

#loginPage .pageTitle {
  font-size: 2em;
  color: var(--primary-color);
}