/* =========================================
   LaBo TV Theme v1.5
   Netflix-style • LG Optimised • Kids Mode
========================================= */

:root {
  --primary: #ff6a00;
  --bg: #0b0b0b;
  --card-radius: 14px;
}

/* ---------- GLOBAL BACKGROUND ---------- */
html,
body,
.skinHeader {
  background-color: var(--bg) !important;
}

/* ---------- REMOVE HEAVY/USELESS UI ---------- */
.sectionTitleTextButton,
.emby-tabs-slider,
.btnUserRating,
.itemMiscInfo,
.cardOverlayButton,
.listItem-border,
.detailImageContainer,
.backdropImage,
.blurHashCanvas {
  display: none !important;
}

/* ---------- SECTION TITLES ---------- */
.sectionTitle {
  font-size: 1.2em !important;
  font-weight: 600;
  margin-left: 12px;
  margin-bottom: 8px;
  color: #ffffff;
}

/* ---------- ROW LAYOUT ---------- */
.itemsContainer {
  display: flex;
  gap: 10px;
  padding-left: 12px;
  margin-bottom: 25px;
  overflow-x: auto;
  scroll-behavior: smooth;
}

/* ---------- LIMIT ITEMS (PERFORMANCE) ---------- */
.itemsContainer .cardBox:nth-child(n+7) {
  display: none;
}

/* ---------- POSTER CARDS ---------- */
.cardBox {
  border-radius: var(--card-radius) !important;
  overflow: hidden;
  width: 170px !important;
  transition: transform 0.12s ease;
  will-change: transform;
}

/* ---------- HOVER ---------- */
.cardBox:hover {
  transform: scale(1.04);
}

/* ---------- HERO ROW ---------- */
.homePage .itemsContainer:first-of-type .cardBox {
  width: 220px !important;
}

/* ---------- TEXT CLEANUP ---------- */
.cardText,
.cardScalable .cardText {
  font-size: 0.75em !important;
  opacity: 0.75;
}

/* ---------- REMOVE EXTRA LABELS ---------- */
.cardIndicators,
.mediaInfoItem,
.cardOverlayContainer {
  display: none !important;
}

/* ---------- HEADER ---------- */
.skinHeader {
  border-bottom: none !important;
}

/* =========================================
   HERO BACKGROUND FIX (NO EMPTY SPACE)
========================================= */

/* Bring back lightweight backdrop */
.backgroundContainer {
  display: block !important;
  opacity: 0.25 !important;
}

/* Gradient overlay */
.backgroundContainer::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0.3) 0%,
    rgba(0,0,0,0.7) 60%,
    rgba(0,0,0,1) 100%
  );
}

/* Lift content */
.homePage .section0 {
  margin-top: -120px;
  padding-top: 120px;
}

/* =========================================
   LOGIN BRANDING
========================================= */

#loginPage {
  background: linear-gradient(180deg, #000000, #111111);
}

#loginPage .pageTitle {
  font-size: 2em;
  color: var(--primary);
  letter-spacing: 1px;
}

/* =========================================
   SCROLLBAR CLEAN
========================================= */

::-webkit-scrollbar {
  height: 6px;
}

::-webkit-scrollbar-thumb {
  background: #333;
  border-radius: 10px;
}

/* =========================================
   KIDS MODE (AUTO DETECT - MODERN DEVICES)
========================================= */

/* Works on newer browsers */
body:has(.headerUserButton[title*="Kids"]) .cardBox {
  width: 230px !important;
}

body:has(.headerUserButton[title*="Kids"]) .homePage .itemsContainer:first-of-type .cardBox {
  width: 260px !important;
}

body:has(.headerUserButton[title*="Kids"]) .cardText,
body:has(.headerUserButton[title*="Kids"]) .sectionTitle {
  display: none !important;
}

body:has(.headerUserButton[title*="Kids"]) .itemsContainer {
  gap: 18px;
}

body:has(.headerUserButton[title*="Kids"]) .skinHeader {
  background: #000 !important;
}

/* =========================================
   KIDS MODE FALLBACK (LG SAFE)
   👉 Manual toggle by uncommenting below
========================================= */


body .cardBox {
  width: 230px !important;
}

body .homePage .itemsContainer:first-of-type .cardBox {
  width: 260px !important;
}

body .cardText,
body .sectionTitle {
  display: none !important;
}

body .itemsContainer {
  gap: 18px;
}

body .skinHeader {
  background: #000 !important;
}

