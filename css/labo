/* =========================================
   LaBo TV — Coming Soon Section
========================================= */

/* Rename visually */
.sectionTitle:has(+ .itemsContainer .cardText:contains("Coming Soon")),
.sectionTitle:contains("Coming Soon") {
  color: #ff6a00 !important;
}

/* Slight glow for featured feel */
.itemsContainer .cardBox {
  box-shadow: 0 0 0px rgba(255,106,0,0);
  transition: all 0.2s ease;
}

.itemsContainer .cardBox:hover {
  box-shadow: 0 0 10px rgba(255,106,0,0.4);
}

/* Optional: dim unreleased feel */
.itemsContainer .cardText {
  opacity: 0.7;
}

/* Coming Soon badge */
.cardBox::after {
  content: "COMING SOON";
  position: absolute;
  top: 8px;
  left: 8px;
  background: rgba(255,106,0,0.9);
  color: #fff;
  font-size: 10px;
  padding: 3px 6px;
  border-radius: 6px;
  z-index: 10;
}

/* =========================================
   LaBo TV — NEW Badge System (LG Safe)
========================================= */

/* ---------- BASE BADGE STYLE ---------- */
.cardBox::before {
  content: "";
  display: none;
}

/* ---------- APPLY TO FIRST ROW (Recently Added) ---------- */
.homePage .itemsContainer:first-of-type .cardBox::before {
  content: "NEW";
  display: block;

  position: absolute;
  top: 8px;
  right: 8px;

  background: linear-gradient(135deg, #00a8e1, #0077b6);
  color: #fff;

  font-size: 11px;
  font-weight: 700;

  padding: 4px 8px;
  border-radius: 6px;

  z-index: 10;
}

/* ---------- ONLY SHOW ON FIRST 5 ITEMS ---------- */
.homePage .itemsContainer:first-of-type .cardBox:nth-child(n+6)::before {
  display: none;
}

/* =========================================
   OPTIONAL: MANUAL TAG SYSTEM (MORE CONTROL)
   Add tag "new" in Jellyfin metadata
========================================= */

.cardBox[data-tags*="new"]::before {
  content: "NEW";
  display: block;

  position: absolute;
  top: 8px;
  right: 8px;

  background: linear-gradient(135deg, #00a8e1, #0077b6);
  color: #fff;

  font-size: 11px;
  font-weight: 700;

  padding: 4px 8px;
  border-radius: 6px;

  z-index: 10;
}

